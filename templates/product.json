center","paddingsection":"80px 0px 80px 0px","paddingmobile":"40px 0px 40px 0px","marginsection":"0px 0px 0px 0px","marginmobile":"0px 0px 0px 0px"}},"30d4e0bd-da81-4442-b71d-c0fd1f5b3906":{"type":"image-content-6","blocks":{"template--14654207721557__30d4e0bd-da81-4442-b71d-c0fd1f5b3906-16658225273f87a081-0":{"type":"image_block","settings":{"style_content":"default","w_image":40,"pos_image":81,"e_image":"right","enable_video":false,"overlay_color":"#000000","overlay_opacity":30,"text_circle":"Fashion2 style store","video_url":""}},"template--14654207721557__30d4e0bd-da81-4442-b71d-c0fd1f5b3906-16658225273f87a081-1":{"type":"text_block","settings":{"bgtext":"#ffffff","subtitle":"Breathable ","title":"Stylish checked & striped 100% cotton shirts for any kind of occasion.","size_text":"h3","text":"","answer_content":"","button":"discover now","link":"","style_btn":"btn-theme","align":"left","enable_padding_left":true,"enable_padding_right":false}}},"block_order":["template--14654207721557__30d4e0bd-da81-4442-b71d-c0fd1f5b3906-16658225273f87a081-0","template--14654207721557__30d4e0bd-da81-4442-b71d-c0fd1f5b3906-16658225273f87a081-1"],"disabled":true,"settings":{"animation":"fade-up","setwidth":"container","bgsection":"#ffffff","size":"50-50","enable_padding":true,"align_center":true,"paddingsection":"100px 0px 100px 0px","paddingmobile":"48px 0px 48x 0px","marginsection":"0px 0px 0px 0px","marginmobile":"0px 0px 0px 0px"}},"bcb1cba3-80fc-49a2-a033-40cf0618e9c8":{"type":"faq-accordion","blocks":{"template--14684877652053__bcb1cba3-80fc-49a2-a033-40cf0618e9c8-16659371170e440ef7-0":{"type":"faq","settings":{"faq_title":"How long does Desire perfume last?","faq_des":"<p>Desire is formulated at up to<strong>40% imported oil concentration<\/strong>— the highest strength available in perfumery — built on a base of Ambergris, Musk, and Driftwood, three of the most tenacious fragrance ingredients available. On most skin types it lasts<strong>12 or more hours<\/strong>, with fabric projection extending even longer. It is genuinely one of the longest-lasting perfumes in its category.<br\/><\/p>"}},"template--14684877652053__bcb1cba3-80fc-49a2-a033-40cf0618e9c8-16659371170e440ef7-1":{"type":"faq","settings":{"faq_title":"Does Desire work well in hot and humid weather like in Kerala or South India?","faq_des":"<p>Yes — and this was intentional. The <strong>high oil concentration and Ambergris–Musk base<\/strong> are chosen precisely because they anchor to skin even in heat and humidity. Most standard perfumes evaporate quickly in India's climate; Desire's <strong>UAE-sourced base notes and up to 40% oil concentration<\/strong> mean the scent holds and evolves rather than disappearing. It is an excellent choice as a <strong>long-lasting perfume for humid weather<\/strong> in Kerala and across South India.<\/p>"}},"template--14684877652053__bcb1cba3-80fc-49a2-a033-40cf0618e9c8-16659371170e440ef7-2":{"type":"faq","settings":{"faq_title":"What makes a high concentration perfume different from a regular one?","faq_des":"<p>Most perfumes you find in malls or online contain just 10–20% fragrance oil — the rest is alcohol and water. <strong>Desire is formulated at up to 40% oil concentration<\/strong>, using oils sourced from the UAE, France and Switzerland. This means more actual fragrance per spray, deeper bonding with your skin, and longevity that regular perfumes simply cannot match. Once you wear a high concentration fragrance, standard perfumes feel thin by comparison<\/p>"}},"faq_f4rwQd":{"type":"faq","settings":{"faq_title":"Is Desire suitable as a gift?","faq_des":"<p>Absolutely. Desire is a unisex high concentration fragrance that works beautifully as a premium gift for birthdays, anniversaries, Eid, Onam, Christmas, or any occasion where you want to give something personal and lasting. These are not generic gifts — they are crafted from oils sourced in the UAE, France and Switzerland. Add a gift note at checkout — we include it at no extra charge.<\/p>"}},"faq_MbnTYD":{"type":"faq","settings":{"faq_title":"Is Nuwe Perfumes hand crafted?","faq_des":"<p>Yes — completely. Nuwe Perfumes is a <strong>small-batch, hand crafted fragrance brand from Kerala<\/strong>. We personally source fragrance oils from the UAE, France and Switzerland, then hand craft every bottle ourselves in small batches. Nothing is factory-made or mass-produced. This is how we maintain the quality, consistency, and oil concentration that our customers rely on.<\/p>"}}},"block_order":["template--14684877652053__bcb1cba3-80fc-49a2-a033-40cf0618e9c8-16659371170e440ef7-0","template--14684877652053__bcb1cba3-80fc-49a2-a033-40cf0618e9c8-16659371170e440ef7-1","template--14684877652053__bcb1cba3-80fc-49a2-a033-40cf0618e9c8-16659371170e440ef7-2","faq_f4rwQd","faq_MbnTYD"],"settings":{"animation":"","setwidth":"container","bgsection":"#ffffff","e_size":"auto","e_repeat":"no-repeat","e_pos":"center center","title_top":"","title":"Frequently Asked Questions","des":"","align-heading":"center","title_size":"h6","e_first_open":false,"e_reverse":true,"e_small":true,"left_html":"","e_right":false,"paddingsection":"80px 0px 100px 0px","paddingmobile":"60px 0px 60px 0px","marginsection":"0px 0px 0px 0px","marginmobile":"0px 0px 0px 0px"}},"16956665928504d885":{"type":"apps","disabled":true,"settings":{"animation":"","setwidth":"container","paddingsection":"40px 0px 20px 0px","paddingmobile":"40px 0px 40px 0px","marginsection":"0px 0px 0px 0px","marginmobile":"0px 0px 0px 0px","bgsection":"#f8f8f8"}},"product-recommendations":{"type":"product-recommendations","settings":{"animation":"fade-up","setwidth":"container","heading":"You may also like","heading_size":"h3","heading_align":"center","products_to_show":10,"spaceBetween":30,"perviewDesktop":4,"nowrap":true,"arrows":true,"scrollbar":true,"padding_top":80,"padding_bottom":32}},"product-recent":{"type":"recently-viewed","settings":{"enable":true,"animation":"fade-up","setwidth":"container","title_top"