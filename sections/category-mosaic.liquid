{% schema %}
{
  "name": "Category Mosaic",
  "max_blocks": 4,
  "settings": [
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Category Title"
        },
        {
          "type": "textarea",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Explore our collection"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Mosaic",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "Perfumes",
            "subtitle": "Discover luxury fragrances"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Attar & Bakhoor",
            "subtitle": "Traditional scents"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Combos",
            "subtitle": "Perfect pairings"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Gifts",
            "subtitle": "For your loved ones"
          }
        }
      ]
    }
  ]
}
{% endschema %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .category-mosaic {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 16px;
  }

  .mosaic-grid {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .mosaic-item {
    position: relative;
    display: block;
    width: 100%;
    height: 200px;
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    background-color: #f3f3f3;
  }

  .mosaic-item img,
  .mosaic-placeholder {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
    z-index: 1;
  }

  .mosaic-item:hover img,
  .mosaic-item:hover .mosaic-placeholder {
    transform: scale(1.08);
  }

  .mosaic-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, transparent 30%, rgba(0, 0, 0, 0.7) 100%);
    z-index: 2;
  }

  .mosaic-content {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 20px;
    z-index: 3;
    pointer-events: none;
  }

  .mosaic-title {
    font-size: 22px;
    font-weight: 600;
    margin: 0 0 4px 0;
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .mosaic-subtitle {
    font-size: 13px;
    margin: 0;
    color: #ffffff;
    opacity: 0.85;
    line-height: 1.4;
  }

  @media (min-width: 768px) {
    .mosaic-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: repeat(3, 180px);
      gap: 20px;
    }

    .mosaic-item {
      height: 100%;
    }

    /* Asymmetrical Layout Logic */
    /* Perfumes (Block 1) - Left Col, 2 Rows */
    .mosaic-item:nth-child(1) {
      grid-column: 1 / 2;
      grid-row: 1 / span 2;
    }

    /* Attar (Block 2) - Right Col, 1 Row Top */
    .mosaic-item:nth-child(2) {
      grid-column: 2 / 3;
      grid-row: 1 / span 1;
    }

    /* Combos (Block 3) - Left Col, bottom row under Perfumes */
    .mosaic-item:nth-child(3) {
      grid-column: 1 / 2;
      grid-row: 3 / span 1;
    }

    /* Gifts (Block 4) - Right Col, 2 rows bottom under Attar */
    .mosaic-item:nth-child(4) {
      grid-column: 2 / 3;
      grid-row: 2 / span 2;
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding">
  <div class="category-mosaic">
    <div class="mosaic-grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '#' }}" class="mosaic-item" role="link" aria-label="{{ block.settings.title | escape }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 1200 | image_tag: 
              loading: 'lazy', 
              sizes: '(min-width: 768px) 50vw, 100vw',
              alt: block.settings.title | escape 
            }}
          {%- else -%}
            {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'mosaic-placeholder' }}
          {%- endif -%}
          
          <div class="mosaic-overlay"></div>
          
          <div class="mosaic-content">
            {%- if block.settings.title != blank -%}
              <h3 class="mosaic-title">{{ block.settings.title | escape }}</h3>
            {%- endif -%}
            {%- if block.settings.subtitle != blank -%}
              <p class="mosaic-subtitle">{{ block.settings.subtitle | escape }}</p>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>